---
import Tag from "./Tag.astro";
interface Props {
  title: string;
  description: string;
  id: string;
  isoStringDate: string;
  formattedDate: string;
  tags: string[];
}
const { title, formattedDate, isoStringDate, description, id, tags } =
  Astro.props;
---

<li transition:name={`writing-card-${title}`}>
  <div class="flex flex-col gap-1">
    <div
      class="flex flex-col items-start justify-between gap-1 sm:flex-row sm:gap-2"
    >
      <h3 class="text-lg">
        <a
          href={`/writing/${id}`}
          class="first-letter:uppercase border-b-2 border-b-foreground/10 transition-colors duration-300 ease-in-out hover:border-b-foreground/60 hover:bg-foreground/5 dark:border-b-foreground/15 hover:dark:bg-foreground/10"
        >
          <span transition:name=`writing-${title}`>{title}</span>
        </a>
      </h3>
      <div class="text-sm text-muted-foreground">
        <time
          datetime={isoStringDate}
          transition:name=`writing-${title}-${isoStringDate}`
          >{formattedDate}</time
        >
      </div>
    </div>
    <p>
      <span>{description}</span>
      {
        tags.length > 0 && (
          <>
            <span>·</span>
            <span class="inline-flex gap-1">
              {tags.map((tag) => (
                <Tag tag={tag} />
              ))}
            </span>
          </>
        )
      }
    </p>
  </div>
</li>
